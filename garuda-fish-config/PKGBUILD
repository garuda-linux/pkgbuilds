# Contributor: Librewish librewish@gmail.com

pkgname=garuda-fish-config
pkgver=2.0.1
pkgrel=2
pkgdesc="Fish configuration of Garuda Linux"
arch=(any)
url="https://garudalinux.org"
license=('MIT')
depends=('bat'
  'eza'
  'expac'
  'fish'
  'fzf'
  'garuda-starship-prompt'
  'pkgfile'
  'tealdeer'
  'ugrep')
makedepends=('git')
source=("garuda-fish-completions-update.service"
  "config.fish"
  "stub.fish"
  "garuda-update.fish"
  "https://raw.githubusercontent.com/franciscolourenco/done/1.21.1/conf.d/done.fish")
sha256sums=('6f7ffc81204fa908a324d0030d211e522ee0b0eee5be34b67ae885de4c02ffe7'
            'bf07cfb6cf85787705ca7564b6bdb9ee2ce4338a3e0121890fe00d2070c64d8f'
            '5bd52660a65ed0666ab2446043f9a85f99f1757f6264dee393187f73d5b1300c'
            '054fb02422a08c63c4fc1a9b59ec1e90775b214a7edf53f003aec27b6c686462'
            '402a83d98d815ff3972cac136d205391a61d6175cc3f8aff15bda018259678ba')

package() {
  cd "$srcdir" || exit
  install -D -m644 stub.fish "$pkgdir"/etc/skel/.config/fish/config.fish
  install -D -m644 config.fish "$pkgdir"/usr/share/garuda/garuda-fish-config/config.fish
  install -Dm0644 garuda-update.fish "$pkgdir/usr/share/fish/vendor_conf.d/garuda-update.fish"
  install -Dm0644 done.fish "$pkgdir/usr/share/fish/vendor_conf.d/done.fish"
  install -Dm0644 garuda-fish-completions-update.service "$pkgdir/usr/lib/systemd/user/garuda-fish-completions-update.service"

  # Workaround for mcfly complaining about missing history
  mkdir -p "$pkgdir"/etc/skel/.local/share/fish
  touch "$pkgdir"/etc/skel/.local/share/fish/fish_history
}
