pkgname=garuda-health
pkgdesc="The Garuda Linux health checker command"
pkgver=1.11.0
pkgrel=1
arch=('any')
license=('GPL-3.0-or-later')
source=("garuda-health")
sha512sums=('c08831d857b9966fa8daaa630756f500862d0df90d29beaa31ef8afe8b53818a179d5fbf4fde2a00f8acd5ad302a454aab1387fcd5e3031293564ea94f599936')

package() {
  depends=('garuda-update' 'pacman' 'python')
  optdepends=('smartmontools: for SMART disk health checks')

  install -Dm755 garuda-health "$pkgdir"/usr/bin/garuda-health
  mkdir -p "$pkgdir"/etc/garuda/garuda-health
}
