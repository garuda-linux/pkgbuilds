pkgname=plasma-applet-window-buttons
pkgver=0.14.0
pkgrel=4
_commit=9b1112474dca0390408ccd0a0bbda5fa18161633
pkgdesc='Plasma applet in order to show window buttons in your panels'
arch=(x86_64)
url='https://github.com/optionmishra/applet-window-buttons6'
license=(GPL-2.0-or-later
  LGPL-2.1-or-later)
depends=(gettext
  glibc
  kcolorscheme
  kconfig
  kcoreaddons
  kdecoration
  ki18n
  kirigami
  kitemmodels
  ksvg
  libplasma
  libstdc++
  plasma-workspace
  qt6-base
  qt6-declarative)
makedepends=(extra-cmake-modules
  git)
conflicts=(plasma5-applets-window-buttons)
replaces=(plasma5-applets-window-buttons)
source=("git+https://github.com/optionmishra/applet-window-buttons6.git#commit=$_commit")
sha256sums=('27c67af84367c78da8e31b83e6690c24b2d85238be7390c02aab7394c0c162a1')

build() {
  cmake -B build -S applet-window-buttons6
  cmake --build build
}

package() {
  DESTDIR="$pkgdir" cmake --install build
}
