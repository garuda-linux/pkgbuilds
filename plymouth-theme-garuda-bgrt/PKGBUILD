# Maintainer: dr460nf1r3 <dr460nf1r3 at garudalinux dot org>

pkgname="plymouth-theme-garuda-bgrt"
pkgdesc="Plymouth theme using the UEFI logo with branding for Garuda Linux"
pkgver=1.0.0
pkgrel=1
arch=("any")
url="https://gitlab.com/garuda-linux/themes-and-settings/artwork/$pkgname"
license=("GPL")
makedepends=("git")
source=("$url/-/archive/$pkgver/plymouth-theme-garuda-bgrt-$pkgver.tar.gz")
sha256sums=('7c0f80ba2ad45b2ad522ba60de3d42f840069d2a5b4ee40158dfc4e236395b90')
install=$pkgname.install

package() {
  install -d "$pkgdir/usr/share/plymouth/themes"
  cp -rf "$srcdir/$pkgname-$pkgver/theme" "$pkgdir/usr/share/plymouth/themes/garuda-bgrt"
}
